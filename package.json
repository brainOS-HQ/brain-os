{
  "name": "brain-os",
  "version": "0.5.2",
  "description": "MCP server for operational state across AI agents. Decisions, plans, blockers, and project state that survive across sessions.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "brain-os": "bin/brain-os.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "serve": "node dist/index.js",
    "test": "npm run build && node --test tests/smoke.mjs",
    "metrics": "node scripts/fetch-metrics.mjs"
  },
  "keywords": [
    "mcp",
    "ai-state",
    "ai-agents",
    "operational-state",
    "model-context-protocol"
  ],
  "author": "Tasha Amanda",
  "homepage": "https://brainos-hq.com",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "openai": "^6.35.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "fast-uri": ">=3.1.2",
    "hono": ">=4.12.18",
    "express-rate-limit": ">=8.5.1",
    "ip-address": ">=10.1.1",
    "protobufjs": ">=7.5.8",
    "qs": ">=6.15.2"
  },
  "engines": {
    "node": ">=18"
  }
}
